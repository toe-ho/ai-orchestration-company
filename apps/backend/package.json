{
  "name": "@aicompany/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "bash scripts/test-db-setup.sh",
    "test:teardown": "bash scripts/test-db-teardown.sh",
    "test:ci": "bash scripts/test-db-setup.sh && pnpm test; EXIT=$?; bash scripts/test-db-teardown.sh; exit $EXIT",
    "db:migrate": "typeorm migration:run -d dist/infrastructure/persistence/data-source.js"
  },
  "dependencies": {
    "@aicompany/shared": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/cqrs": "^10.2.0",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "better-auth": "^1.5.5",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "fastify": "^4.26.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
