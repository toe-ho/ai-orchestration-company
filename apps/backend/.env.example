# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgres://user:password@localhost:5432/aicompany

# Auth
AUTH_SECRET=change-me-openssl-rand-base64-32
AUTH_URL=http://localhost:3100
AGENT_JWT_SECRET=change-me-openssl-rand-base64-32
AGENT_JWT_TTL_SECONDS=172800

# Fly.io (Execution Plane)
FLY_API_TOKEN=change-me
FLY_APP_NAME=aicompany-vms
FLY_REGION=sjc
FLY_VM_SIZE=shared-cpu-2x
FLY_IDLE_TIMEOUT_MIN=10

# Redis
REDIS_URL=redis://localhost:6379

# Storage
S3_BUCKET=aicompany-assets
S3_REGION=us-east-1
S3_ENDPOINT=

# Encryption
ENCRYPTION_KEY=change-me-openssl-rand-base64-32

# Features
MAX_AGENTS_PER_COMPANY=20
MAX_HIRE_DEPTH=3
